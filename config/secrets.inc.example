[!]
-------------------------------------------------------------------------------
  config/secrets.inc.example  —  per-box secrets template (TRACKED in git)
-------------------------------------------------------------------------------
  SETUP: copy this file to  config/secrets.inc  on each box and fill it in.
         config/secrets.inc is gitignored and must NEVER be committed.

      cp config/secrets.inc.example config/secrets.inc
      # then edit config/secrets.inc with this box's real values

  USAGE: include it once near the top of every privileged template:

      [include file=config/secrets.inc]
      ... now [LINODE_API_TOKEN] etc. are available as WebDNA text vars ...

  NOTES:
   - The Linode token is a SCOPED personal access token: scope it to only what
     the console uses. Use a SEPARATE dev token from the prod token.
   - These are WebDNA [text] assignments — values are plain text. Keep this
     file outside any served path / behind auth + IP lockdown. It holds the
     keys to billable infrastructure.
-------------------------------------------------------------------------------
[/!]

[!]-- Linode (Akamai Cloud) API --[/!]
[text show=F]LINODE_API_TOKEN=PUT-SCOPED-DEV-PAT-HERE[/text]
[text show=F]LINODE_API_BASE=https://api.linode.com/v4[/text]

[!]-- Object Storage (S3-compatible) — for off-box .db backups --[/!]
[text show=F]LINODE_OBJ_ACCESS_KEY=[/text]
[text show=F]LINODE_OBJ_SECRET_KEY=[/text]
[text show=F]LINODE_OBJ_ENDPOINT=https://ap-south-1.linodeobjects.com[/text]
[text show=F]LINODE_OBJ_BUCKET=console-db-backups[/text]

[!]-- Console auth + IP lockdown (read X-Forwarded-For behind the proxy) --[/!]
[text show=F]CONSOLE_ALLOWED_IPS=[/text]

[!]-- Integration boundary (optional sidecar — stub only) --[/!]
[text show=F]INTEGRATION_BASE_URL=http://127.0.0.1:8000[/text]
[text show=F]INTEGRATION_SHARED_SECRET=[/text]
